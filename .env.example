# Anthropic API key (Claude Opus 4.7 へのアクセス用)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic モデル ID (デフォルトは Opus 4.7)
ANTHROPIC_MODEL=claude-opus-4-7

# Ahrefs API token (オプション。未設定の場合はモックデータ使用)
# https://ahrefs.com/api
AHREFS_API_TOKEN=

# 動作モード: "live" (実APIコール) または "mock" (ダミーデータ表示のみ)
APP_MODE=mock

# ─── 管理者専用ログ閲覧機能 ───
# URL に ?admin=<ADMIN_URL_KEY> を付けてアクセスすると、サイドバーに管理者ログイン欄が出現。
# パスワード一致で全分析ログを管理画面で閲覧できる。
ADMIN_PASSWORD=
ADMIN_URL_KEY=secretkey-bw

# Neon (Postgres) 接続URL。未設定なら SQLite (/tmp/seo_logs.db) を使用 (Render再デプロイで消える点に注意)
# Neon無料プランの取得元: https://neon.tech (3GB / 無期限)
# 例: postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
