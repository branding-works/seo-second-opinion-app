# Anthropic API key (Claude Opus 4.7 へのアクセス用)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic モデル ID (デフォルトは Opus 4.7)
ANTHROPIC_MODEL=claude-opus-4-7

# Ahrefs API token (オプション。未設定の場合はモックデータ使用)
# https://ahrefs.com/api
AHREFS_API_TOKEN=

# 動作モード: "live" (実APIコール) または "mock" (ダミーデータ表示のみ)
APP_MODE=mock
